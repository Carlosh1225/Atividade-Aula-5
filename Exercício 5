#include <stdio.h>
int main() {
    char texto[51] = "ola, mundo";
    int v = 0;
    int c = 0;

    for (int i = 0; texto[i] != '\0'; i++) {
        char letra = texto[i];

        // Verifica se e uma letra minuscula (a-z)
        if (letra >= 'a' && letra <= 'z') {
            if (letra == 'a' || letra == 'e' || letra == 'i' || letra == 'o' || letra == 'u') {
                v++;
            } else {
                c++;
            }
        }
    }

    printf("%d %d\n", v, c);

    return 0;
}
