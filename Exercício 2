#include <stdio.h>

// Função que processa o pico de audiência
int calcular_pico_audiencia(int *dados, int n) {
    int recorde = 0;

    // Percorremos o vetor comparando pares
    for (int i = 0; i < n - 1; i++) {
        int soma_par = dados[i] + dados[i+1];
        
        if (soma_par > recorde) {
            recorde = soma_par;
        }
    }
    return recorde;
}

int main() {
    // Simulando 6 dias de métricas de uma playlist
    int metricas[] = {45, 92, 110, 88, 205, 190};
    int total = 6;

    int resultado = calcular_pico_audiencia(metricas, total);

    printf("Relatorio de Engajamento:\n");
    printf("O maior volume em 48h seguidas foi de: %d plays.\n", resultado);

    return 0;
}
